{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heimgewebe.github.io/konvergenzregelkreis/protocol/closure-receipt.v2.schema.json",
  "title": "Closure Receipt v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "closure_id",
    "status",
    "residual_risks"
  ],
  "properties": {
    "schema_version": {
      "const": 2
    },
    "closure_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "status": {
      "enum": [
        "proposed",
        "closed"
      ]
    },
    "bureau_task_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "chronik_event_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "cleanup_evidence": {
      "type": "array",
      "uniqueItems": true,
      "maxItems": 64,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 2048
      }
    },
    "recovery_evidence": {
      "type": "array",
      "uniqueItems": true,
      "maxItems": 64,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 2048
      }
    },
    "degraded_mode_evidence": {
      "type": "array",
      "uniqueItems": true,
      "maxItems": 64,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 2048
      }
    },
    "return_to_primary_evidence": {
      "type": "array",
      "uniqueItems": true,
      "maxItems": 64,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 2048
      }
    },
    "residual_risks": {
      "type": "array",
      "uniqueItems": true,
      "maxItems": 64,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500
      }
    }
  }
}
