{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heimgewebe.github.io/konvergenzregelkreis/protocol/classification.v1.schema.json",
  "title": "Classification v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "change_class",
    "semantic_change",
    "blocked_by"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "change_class": {
      "enum": [
        "documentation",
        "contract",
        "application",
        "runtime",
        "infrastructure",
        "security",
        "data",
        "lifecycle",
        "product_outcome"
      ]
    },
    "semantic_change": {
      "enum": [
        "none",
        "possible",
        "material",
        "unknown"
      ]
    },
    "blocked_by": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 300
      },
      "maxItems": 64
    }
  }
}
