{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heimgewebe.github.io/konvergenzregelkreis/protocol/observation.v1.schema.json",
  "title": "Observation v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "observation_id",
    "observed_at",
    "source_state",
    "source_refs",
    "claims",
    "does_not_establish"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "observation_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_state": {
      "enum": [
        "current",
        "stale",
        "unknown"
      ]
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "ref",
          "subject_sha256"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "ref": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2048
          },
          "subject_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        }
      },
      "maxItems": 32
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500
      },
      "maxItems": 64
    },
    "does_not_establish": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 200
      },
      "maxItems": 64
    }
  }
}
