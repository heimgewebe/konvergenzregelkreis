{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heimgewebe.github.io/konvergenzregelkreis/protocol/assessment-request.v1.schema.json",
  "title": "Assessment Request v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "assessment_id",
    "risk_level",
    "observation",
    "classification",
    "effects",
    "verifications"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "assessment_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "risk_level": {
      "enum": [
        "R0",
        "R1",
        "R2",
        "R3"
      ]
    },
    "observation": {
      "$ref": "observation.v1.schema.json"
    },
    "classification": {
      "$ref": "classification.v1.schema.json"
    },
    "effects": {
      "type": "array",
      "items": {
        "$ref": "effect-receipt.v1.schema.json"
      },
      "maxItems": 64
    },
    "verifications": {
      "type": "array",
      "items": {
        "$ref": "verification-receipt.v1.schema.json"
      },
      "maxItems": 128
    },
    "closure": {
      "$ref": "closure-receipt.v1.schema.json"
    }
  }
}
